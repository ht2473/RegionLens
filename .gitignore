# Окружение и секреты
.env
!.env.example

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
build/
dist/

# Django
/db.sqlite3
staticfiles/
media/

# Инструменты
.mypy_cache/
.pytest_cache/
.ruff_cache/

# Данные: промежуточные/итоговые пересоздаются конвейером; сырьё — под DVC.
data/interim/
data/processed/

# ML/эксперименты
mlruns/
mlartifacts/
mlflow.db
mlflow.db-journal

# IDE / OS
.idea/
.vscode/
.DS_Store

# Планы проекта
# Артефакты в docs/ не версионируются, но Markdown-документация — версионируется.
docs/**
!docs/**/
!docs/**/*.md
!docs/.gitkeep

# Сгенерированное аналитическое хранилище DuckDB (пересоздаётся пайплайном).
# Прочие *.duckdb игнорируются, а основной файл витрины версионируется через Git LFS
# (см. .gitattributes) — чтобы приложение поднималось «из коробки» без пересборки данных.
data/*.duckdb
!data/regionlens.duckdb
# Рабочие каталоги обновления витрины (refresh_data): staging-сборка,
# ротация бэкапов и каталог приёма ручных выгрузок — только локальное состояние.
data/staging/
data/backups/
data/incoming/

# Локальные артефакты пайплайна/приложения (пересоздаются; в репо не нужны)
data/geo/
schema.yml

# Скрипты для дампов
scripts/
dump/

# Мониторинг проекта 
.VSCodeCounter/

# Артефакты измерения покрытия тестами
.coverage
.coverage.*
htmlcov/
coverage.xml
