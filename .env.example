# ============================================================================
# RegionLens — шаблон переменных окружения. Скопируйте в файл .env и заполните.
# Файл .env в репозиторий не попадает (он в .gitignore).
#
#   • для локальной разработки достаточно секции DEV;
#   • для боевого VPS используйте секцию PRODUCTION (docker-compose.prod.yml).
# ============================================================================

# ---------------------------------------------------------------------------
# DEV — локальная разработка (python main.py / docker-compose.yml)
# ---------------------------------------------------------------------------
DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DATABASE_URL=postgres://regionlens:regionlens@localhost:5432/regionlens
DUCKDB_PATH=data/regionlens.duckdb

# ---------------------------------------------------------------------------
# PRODUCTION — боевой VPS (docker-compose.prod.yml)
# ---------------------------------------------------------------------------
# Раскомментируйте и заполните под свой сервер. При DJANGO_DEBUG=false
# автоматически включаются HTTPS-редирект, secure-cookies и HSTS
# (проверяется чистым `python backend/manage.py check --deploy`).

# Обязательное. Длинный случайный ключ, напр.:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
# DJANGO_SECRET_KEY=

# Ваш домен и/или IP сервера (через запятую, без схемы).
# DJANGO_ALLOWED_HOSTS=regionlens.example.com,203.0.113.10

# Доверенные источники для проверки CSRF за HTTPS-прокси — СО СХЕМОЙ.
# Без этого POST-формы (вход, смена языка, избранное) вернут 403.
# DJANGO_CSRF_TRUSTED_ORIGINS=https://regionlens.example.com

# Домен для nginx (подставляется в конфиг через envsubst).
# DOMAIN=regionlens.example.com

# Порт публикации nginx на хосте. 80 — если TLS терминирует хостовой прокси/Caddy;
# 8080 — если перед этим стеком стоит внешний reverse-proxy.
# HTTP_PORT=80

# СУБД: заданные креды используются и приложением, и контейнером postgres.
# POSTGRES_USER=regionlens
# POSTGRES_PASSWORD=
# POSTGRES_DB=regionlens

# Кэш/сессии/троттлинг в проде — общий Redis (в compose поднимается автоматически).
# REDIS_URL=redis://redis:6379/0

# Пароль администратора Grafana (только при запуске профиля monitoring).
# GRAFANA_PASSWORD=
# GRAFANA_PORT=3000

# Лимиты частоты запросов к API (по умолчанию 120/min аноним, 600/min по токену).
# THROTTLE_ANON=120/min
# THROTTLE_USER=600/min

# Обновление витрины (management-команда refresh_data):
# каталог приёма parquet-выгрузок и путь к реестру источников конвейера.
# DATA_INCOMING_DIR=data/incoming
# SOURCES_REGISTRY=config/sources.yaml

# ---------------------------------------------------------------------------
# Точечные переопределения безопасности (нужны редко)
# ---------------------------------------------------------------------------
# Отключите DJANGO_TRUST_PROXY_SSL, если приложение НЕ за TLS-терминирующим
# прокси (иначе возможен цикл редиректов). В docker-compose.prod.yml включён.
# DJANGO_TRUST_PROXY_SSL=true
# DJANGO_SECURE_SSL_REDIRECT=true
# DJANGO_SESSION_COOKIE_SECURE=true
# DJANGO_CSRF_COOKIE_SECURE=true
# DJANGO_SECURE_HSTS_SECONDS=31536000
# DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=true
# DJANGO_SECURE_HSTS_PRELOAD=true

# ---------------------------------------------------------------------------
# Трекинг ошибок — Sentry или self-hosted GlitchTip (опционально)
# ---------------------------------------------------------------------------
# Задайте SENTRY_DSN, чтобы отправлять исключения в приёмник (тот же протокол
# у облачного Sentry и у self-hosted GlitchTip). Пусто — трекинг выключен.
# Персональные данные (email/IP) не отправляются.
# SENTRY_DSN=https://<key>@<host>/<project>
# SENTRY_ENVIRONMENT=production
# SENTRY_RELEASE=regionlens@1.0.0
# Доля трассируемых запросов для performance-мониторинга (0.0 — только ошибки).
# SENTRY_TRACES_SAMPLE_RATE=0.0
