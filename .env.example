# Шаблон окружения. Реальный .env — в .gitignore.
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DATABASE_URL=postgres://regionlens:regionlens@localhost:5432/regionlens
DUCKDB_PATH=data/regionlens.duckdb

# --- Боевое развёртывание (Ф12a) ---
# В проде задайте DJANGO_DEBUG=false и длинный случайный DJANGO_SECRET_KEY —
# тогда HTTPS-редирект, secure-cookies и HSTS включатся автоматически
# (чистый `python backend/manage.py check --deploy`).
# Точечные переопределения ниже нужны редко. Отключите DJANGO_TRUST_PROXY_SSL,
# если приложение НЕ за TLS-терминирующим прокси (иначе возможен цикл редиректов).
# DJANGO_TRUST_PROXY_SSL=true
# DJANGO_SECURE_SSL_REDIRECT=true
# DJANGO_SESSION_COOKIE_SECURE=true
# DJANGO_CSRF_COOKIE_SECURE=true
# DJANGO_SECURE_HSTS_SECONDS=31536000
# DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=true
# DJANGO_SECURE_HSTS_PRELOAD=true
