# Шаблон окружения. Скопируйте в .env и заполните. Реальный .env — в .gitignore.
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DATABASE_URL=postgres://regionlens:regionlens@localhost:5432/regionlens
DUCKDB_PATH=data/regionlens.duckdb
