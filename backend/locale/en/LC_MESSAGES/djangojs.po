msgstr "No previous year to compare."

msgid "Нет предыдущего года для разложения индекса."
msgstr "No previous year for the index decomposition."

msgid "Нет данных SHAP за год."
msgstr "No SHAP data for the year."

msgid "Нет данных о переходах."
msgstr "No transition data."

msgid "Нет данных о двойниках за выбранный год."
msgstr "No twins data for the selected year."

msgid "косинусная близость профиля z-оценок (1.00 — идентичный профиль)"
msgstr "cosine similarity of the z-score profile (1.00 — identical profile)"

